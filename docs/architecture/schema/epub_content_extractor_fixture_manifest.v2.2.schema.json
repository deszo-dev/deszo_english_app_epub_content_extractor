{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.deszo.local/epub_content_extractor_fixture_manifest.v2.2.schema.json",
  "title": "EpubContentExtractorFixtureManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixture_id",
    "kind",
    "purpose",
    "generator",
    "expected_artifacts"
  ],
  "properties": {
    "fixture_id": {
      "type": "string",
      "pattern": "^[A-Z0-9_.-]+$"
    },
    "kind": {
      "enum": [
        "valid_epub",
        "invalid_zip",
        "invalid_file",
        "synthetic_book_object",
        "config_only",
        "fault_injection"
      ]
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "generator": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "tool",
        "version_policy"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "version_policy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "expected_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config",
        "expected_normalized_result"
      ],
      "properties": {
        "config": {
          "type": "string"
        },
        "expected_normalized_result": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason_no_golden": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
