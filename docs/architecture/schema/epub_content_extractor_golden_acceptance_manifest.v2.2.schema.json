{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.deszo.local/epub_content_extractor_golden_acceptance_manifest.v2.2.schema.json",
  "title": "EpubContentExtractorGoldenAcceptanceManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "manifest_version",
    "rule",
    "minimum_required_goldens",
    "status"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "pattern": "^[A-Za-z][A-Za-z0-9+.-]*:"
    },
    "manifest_version": {
      "const": "epub_content_extractor_golden_acceptance_manifest.v2.2"
    },
    "rule": {
      "type": "string",
      "minLength": 1
    },
    "minimum_required_goldens": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^tests/fixtures/epub_content_extractor/.+/expected\\.normalized\\.json$"
      }
    },
    "status": {
      "enum": [
        "pending_until_real_goldens_committed",
        "complete"
      ]
    }
  }
}
